{
  "name": "skills-doctor",
  "version": "0.4.1",
  "description": "Interactive CLI that scans and repairs Agent Skills quality issues.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "bin": {
    "skills-doctor": "bin/skills-doctor.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin/**",
    "dist/**",
    "scripts/**",
    "skills/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "CI=true vitest run",
    "build": "tsc -p tsconfig.build.json",
    "verify": "bun run check && bun run typecheck && bun run test && bun run build",
    "pack:dry-run": "bun pm pack --dry-run",
    "release:notes": "node scripts/extract-release-notes.mjs",
    "dev": "node bin/skills-doctor.js"
  },
  "keywords": [
    "agent",
    "cli",
    "claude",
    "codex",
    "skills"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "commander": "^15.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
